# ─────────────────────────────────────────────────────────────────────────────
# VeriClaim AI — Environment Variables
# Guidewire DEVTrails 2026
#
# Copy this file to .env and fill in your values.
# Never commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# Render PostgreSQL external URL (or local SQLite for dev: sqlite:///./vericlaim.db)
DATABASE_URL=postgresql+psycopg2://postgres:Sart2012%40@localhost:5432/insurance_db


# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set true  → both weather + traffic return hardcoded heavy-rain/flood scenario
# Set false → live APIs are called (with smart fallback if they fail)
# Flip this for your judge demo without touching any code.
DEMO_MODE=false


# ── Weather API (WeatherAPI.com) ───────────────────────────────────────────────
# Already registered: https://www.weatherapi.com/
# Free tier: 1M calls/month — enough for hackathon + production pilot
# Includes: current conditions, precipitation mm, wind, visibility, AQI
WEATHER_API_KEY=42d6b4094f5a43c39eb83334261503

# Optional: timeout in seconds (default 5)
# WEATHER_API_TIMEOUT_S=5


# ── Traffic API (TomTom — completely free, no credit card) ────────────────────
# Sign up: https://developer.tomtom.com  → My Apps → Create New App
#          Enable "Traffic" product on the key
# Free tier: 2,500 requests/day (75,000/month) — no credit card required
#
# What it returns: currentSpeed + freeFlowSpeed → congestion ratio
# If this is blank → system uses the built-in Chennai smart fallback
# (zone-aware + peak-hour + monsoon multiplier — no random(), always realistic)
TOMTOM_API_KEY=jjw8fxsR531PlfgkV7iJ6Vq8v0SyRXCi

# Optional: timeout in seconds (default 5)
# TRAFFIC_API_TIMEOUT_S=5


# ── APScheduler Trigger Monitor ───────────────────────────────────────────────
# How often the automated trigger cycle runs (minutes)
# Set to 1 for demo, 5 for production
# TRIGGER_POLL_INTERVAL_MINUTES=5
